#include <iostream>
#include <string>
#include <algorithm>
using namespace std;

const int col = 10;
const int row = 3;

class CountMinSketch {
private:
    int table[row][col];

    // Hash functions (based on first character)
    int hash1(const string& key) {
        if (key.empty()) return 0;
        return (int(key[0])) % col;
    }

    int hash2(const string& key) {
        if (key.empty()) return 0;
        return (int(key[0]) + 2) % col;
    }

    int hash3(const string& key) {
        if (key.empty()) return 0;
        return (int(key[0]) * 4) % col;
    }

public:
    // Constructor: initialize table with 0
    CountMinSketch() {
        for (int i = 0; i < row; ++i)
            for (int j = 0; j < col; ++j)
                table[i][j] = 0;
    }

    // Insert item
    void insert(const string& item, int count = 1) {
        table[0][hash1(item)] += count;
        table[1][hash2(item)] += count;
        table[2][hash3(item)] += count;
    }

    // Find estimated count
    int FindCount(const string& item) {
        int c1 = table[0][hash1(item)];
        int c2 = table[1][hash2(item)];
        int c3 = table[2][hash3(item)];

        return min(c1, min(c2, c3));
    }
};

int main() {
    CountMinSketch cms;
    string input;
    int n;

    cout << "How many inputs are there: ";
    cin >> n;

    for (int i = 1; i <= n; i++) {
        cout << "Enter the input " << i << ": ";
        cin >> input;

        cms.insert(input);

        cout << "Count for " << input << " = "
             << cms.FindCount(input) << endl;
    }

    return 0;
}
